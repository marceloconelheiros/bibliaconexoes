# Copie para .env e preencha (Vite injeta apenas variáveis com prefixo VITE_)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_anon_publica
VITE_SUPABASE_PROJECT_ID=seu_project_ref

# Opcional — só se quiser outra pasta/base que não seja o bucket público "audios" do próprio projeto.
# Tem de ser Storage: …/storage/v1/object/public/audios  (NÃO use …/rest/v1/object/… — isso devolve 401 sem chave.)
# VITE_PUBLIC_AUDIO_BASE_URL=https://SEU_PROJECT.supabase.co/storage/v1/object/public/audios

# Layout opcional no Storage: pastas antes de Velho/Novo Testamento (ex.: files/audio/biblia).
# Por defeito as pastas de testamento são «Velho Testamento» e «Novo Testamento» (livros OT/NT na tabela books).
# VITE_SUPABASE_AUDIOS_BUCKET=audios
# VITE_SUPABASE_AUDIOS_PREFIX=files/audio/biblia
# VITE_SUPABASE_AUDIOS_FOLDER_OT=Velho Testamento
# VITE_SUPABASE_AUDIOS_FOLDER_NT=Novo Testamento
