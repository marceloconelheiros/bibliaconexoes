# Copie para .env e preencha (Vite injeta apenas variáveis com prefixo VITE_)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_anon_publica
VITE_SUPABASE_PROJECT_ID=seu_project_ref

# Opcional — áudios no Storage público "audios" sem preencher audio_url em cada linha:
# URL até a pasta do bucket (sem barra no final), ex.:
# VITE_PUBLIC_AUDIO_BASE_URL=https://SEU_PROJECT_REF.supabase.co/storage/v1/object/public/audios
# Arquivos esperados: {abbrev}.mp3 (livros) e {abbrev}_PS1.mp3 … {abbrev}_PS5.mp3 (Salmos), usando abbrev de public.books
# VITE_PUBLIC_AUDIO_BASE_URL=
